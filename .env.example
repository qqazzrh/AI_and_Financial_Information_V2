# SEC EDGAR — required for Material Event, Financing/Dilution, Investor Communication adapters
# Format: "CompanyName email@example.com"
SEC_EDGAR_USER_AGENT="YourCompany you@example.com"

# Anthropic — required for "api" analysis mode (per-token fees)
ANTHROPIC_API_KEY=sk-ant-...

# Analysis client mode: "moonshot" (Kimi API), "cli" (Claude CLI), "api" (Anthropic SDK), "mock"
# ANALYSIS_CLIENT_MODE=moonshot

# Moonshot AI (Kimi) — required for "moonshot" analysis mode
MOONSHOT_API_KEY=sk-...

# openFDA — optional; increases rate limit from 240/min to 120k/day
OPENFDA_API_KEY=

# Voyage AI — required for live embeddings (replaces Ollama on Railway)
VOYAGE_AI_API_KEY=voyage-...

# API Server: uvicorn api_server:app --reload --port 8000
